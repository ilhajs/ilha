{
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter ilha build && bun run --filter '@ilha/*' build",
    "cleanup": "bun run --parallel --filter '*' cleanup && rimraf node_modules bun.lock",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "prepare": "husky",
    "test": "bun run --parallel --filter './packages/*' test"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.6",
    "@types/bun": "^1.3.14",
    "husky": "^9.1.7",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "rimraf": "^6.1.3",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  }
}
