{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "ilha",
    "paths": {
      "ilha": ["./src/index.ts"],
      "ilha/jsx-runtime": ["./src/jsx-runtime.ts"],
      "ilha/jsx-dev-runtime": ["./src/jsx-dev-runtime.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["happydom.ts", "dist", "node_modules"]
}
